    </main>

    <footer class="bg-navy-950 text-slate-400 border-t border-navy-900 py-10 px-4 sm:px-10 relative z-10 mt-auto font-inter">
        <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-8 mb-6"><div class="md:col-span-5 space-y-3"><div class="flex items-center gap-3"><img src="<%= data.site.logo %>" alt="FTF Academy Logo Footer" class="h-10 w-10 object-contain bg-white rounded-full p-0.5"><span class="text-white font-extrabold text-sm sm:text-base leading-none uppercase tracking-tight"><%= data.site.name %></span></div><p class="text-xs leading-relaxed max-w-sm"><%= data.footer.description %></p></div><div class="md:col-span-4 font-inter"><h4 class="text-white font-bold text-xs sm:text-sm mb-3 uppercase tracking-wider font-poppins">Flagship Offering</h4><ul class="space-y-2 text-xs"><% data.footer.offerings.forEach(function(offering) { %><li><span class="hover:text-white transition-colors block"><%= offering %></span></li><% }) %></ul></div><div class="md:col-span-3"><h4 class="text-white font-bold text-xs sm:text-sm mb-3 uppercase tracking-wider font-poppins">Contact & Help</h4><p class="text-xs leading-relaxed">Primary Helpline:<br><strong class="text-white text-base"><%= data.footer.phone %></strong></p></div></div><div class="max-w-7xl mx-auto border-t border-navy-900 pt-6 flex flex-col sm:flex-row items-center justify-between text-[11px] text-slate-500 gap-4"><p>© <%= data.site.year %> <%= data.site.name %>. All rights reserved.</p><div class="flex space-x-4"><span><%= data.site.tagline %></span></div></div></footer>

    <div id="success-modal" class="fixed inset-0 z-50 bg-slate-900/60 backdrop-blur-sm flex items-center justify-center p-4 hidden"><div class="bg-white rounded-2xl max-w-sm w-full p-6 text-center space-y-4 shadow-2xl border border-slate-100"><div class="w-12 h-12 bg-emerald-100 text-emerald-600 rounded-full flex items-center justify-center mx-auto"><i data-lucide="check-circle" class="w-7 h-7"></i></div><h3 class="text-lg font-bold text-navy-900 font-poppins">Inquiry Received</h3><p class="text-slate-500 text-xs leading-relaxed font-inter">Thank you! Your institutional enquiry has been registered. Our Academic Directors will get in touch with you.</p><button onclick="closeSuccessModal()" class="w-full bg-navy-900 hover:bg-navy-850 text-white font-bold py-2.5 rounded-lg text-xs font-inter">Close</button></div></div>

    <script>
        let activeTabId = 'home';
        let currentTrackerGrade = 6;
        const gradeTrackerData = <%- JSON.stringify(data.tracker.data) %>;
        window.onload = function() {
            lucide.createIcons();
            renderSyllabusTracker(6);
        };
        function switchTab(tabId) {
            activeTabId = tabId;
            document.querySelectorAll('.tab-view').forEach(tab => { tab.classList.add('hidden'); tab.classList.remove('block'); });
            const targetTab = document.getElementById(`tab-content-${tabId}`);
            if (targetTab) { targetTab.classList.remove('hidden'); targetTab.classList.add('block'); }
            ['home','about','partnership','programmes','tracker','why','contact'].forEach(id => {
                const btn = document.getElementById(`nav-${id}`);
                if (btn) btn.className = id===tabId ? "px-3 sm:px-4 py-2 rounded-md text-xs sm:text-sm font-bold transition-colors text-black bg-slate-100" : "px-3 sm:px-4 py-2 rounded-md text-xs sm:text-sm font-bold transition-colors text-black hover:text-black hover:bg-slate-100";
            });
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
        function switchGradeTab(grade) {
            document.querySelectorAll('.grade-panel').forEach(p => { p.classList.add('hidden'); p.classList.remove('block'); });
            const targetPanel = document.getElementById(`grade-content-${grade}`);
            if (targetPanel) { targetPanel.classList.remove('hidden'); targetPanel.classList.add('block'); }
            [6,7,8,9,10].forEach(g => {
                const btn = document.getElementById(`grade-tab-${g}`);
                if (btn) btn.className = g===grade ? "px-4 py-2 text-xs sm:text-sm font-bold rounded-lg transition-all text-orange-900 bg-orange-50 border border-orange-100 shadow-sm" : "px-4 py-2 text-xs sm:text-sm font-bold rounded-lg transition-all text-orange-600 hover:text-orange-900 hover:bg-orange-50";
            });
        }
        function switchTrackerGrade(grade) {
            currentTrackerGrade = grade;
            [6,7,8,9,10].forEach(g => {
                const tab = document.getElementById(`tracker-tab-${g}`);
                if (tab) tab.className = g===grade ? "px-4 py-2 text-xs font-bold rounded-lg transition-all text-orange-900 bg-orange-50 shadow-sm" : "px-4 py-2 text-xs font-bold rounded-lg transition-all text-orange-600 hover:text-orange-900";
            });
            renderSyllabusTracker(grade);
        }
        function renderSyllabusTracker(grade) {
            const container = document.getElementById('tracker-syllabus-lists');
            if (!container) return;
            const records = gradeTrackerData[grade] || [];
            if (!records.length) { container.innerHTML = `<div class="p-8 text-center text-slate-500 font-inter">No syllabus details available for Grade ${grade}.</div>`; return; }
            let html = `<table class="min-w-full divide-y divide-slate-200 text-left text-xs sm:text-sm font-inter"><thead class="bg-slate-50 text-[10px] sm:text-xs font-bold text-slate-500 uppercase tracking-wider font-poppins"><tr><th class="px-4 py-3 sm:px-6">Subject</th><th class="px-4 py-3 sm:px-6">Chapter / Topic Name</th><th class="px-4 py-3 sm:px-6">Status</th><th class="px-4 py-3 sm:px-6 text-center">Chapter-wise Exam Date</th></tr></thead><tbody class="divide-y divide-slate-150 bg-white">`;
            records.forEach(row => {
                let subjectBadge = '';
                if (row.subject === 'Mathematics') subjectBadge = '<span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold bg-navy-100 text-navy-900">Mathematics</span>';
                else if (row.subject === 'Physics') subjectBadge = '<span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold bg-indigo-100 text-indigo-800">Physics</span>';
                else if (row.subject === 'Chemistry') subjectBadge = '<span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold bg-amber-100 text-amber-800">Chemistry</span>';
                else if (row.subject === 'Biology') subjectBadge = '<span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold bg-emerald-100 text-emerald-800">Biology</span>';
                let statusBadge = '';
                if (row.status === 'Completed') statusBadge = '<span class="inline-flex items-center gap-1 text-xs font-medium text-emerald-700"><span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>Completed</span>';
                else if (row.status === 'In Progress') statusBadge = '<span class="inline-flex items-center gap-1 text-xs font-medium text-blue-700"><span class="w-1.5 h-1.5 rounded-full bg-blue-500 animate-pulse"></span>In Progress</span>';
                else statusBadge = '<span class="inline-flex items-center gap-1 text-xs font-medium text-slate-400"><span class="w-1.5 h-1.5 rounded-full bg-slate-300"></span>Planned</span>';
                html += `<tr class="hover:bg-slate-50/50 transition-colors"><td class="whitespace-nowrap px-4 py-3 sm:px-6 font-semibold">${subjectBadge}</td><td class="px-4 py-3 sm:px-6 font-medium text-slate-800">${row.chapter}</td><td class="whitespace-nowrap px-4 py-3 sm:px-6">${statusBadge}</td><td class="whitespace-nowrap px-4 py-3 sm:px-6 text-center font-mono font-bold text-slate-400 bg-slate-50/30">${row.examDate}</td></tr>`;
            });
            html += `</tbody></table>`;
            container.innerHTML = html;
        }
        function handleFormSubmission(event) {
            event.preventDefault();
            document.getElementById('success-modal').classList.remove('hidden');
            const f1 = document.getElementById('partnership-enquiry-form');
            const f2 = document.getElementById('contact-form');
            if (f1) f1.reset();
            if (f2) f2.reset();
        }
        function closeSuccessModal() {
            document.getElementById('success-modal').classList.add('hidden');
        }
        const pageHeader = document.querySelector('.page-header');
        const scrollThreshold = 90;
        const updateHeaderState = () => {
            if (!pageHeader) return;
            const currentScrollY = window.pageYOffset;
            if (currentScrollY > scrollThreshold) {
                pageHeader.classList.add('condensed');
            } else {
                pageHeader.classList.remove('condensed');
            }
        };
        let isScrollTicking = false;
        window.addEventListener('scroll', function() {
            if (!isScrollTicking) {
                isScrollTicking = true;
                window.requestAnimationFrame(() => {
                    updateHeaderState();
                    isScrollTicking = false;
                });
            }
        }, { passive: true });
    </script>
</body>
</html>
