<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= data.site.title %></title>
    <meta name="description" content="<%= data.site.description %>">
    <meta name="keywords" content="<%= data.site.keywords %>">
    <meta name="author" content="<%= data.site.author %>">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="<%= data.site.canonical %>">
    <meta property="og:title" content="<%= data.site.title %>">
    <meta property="og:description" content="<%= data.site.description %>">
    <meta property="og:image" content="<%= data.site.ogImage %>">
    <meta property="og:url" content="<%= data.site.url %>">
    <meta property="og:type" content="website">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= data.site.title %>">
    <meta name="twitter:description" content="<%= data.site.description %>">
    <meta name="twitter:image" content="<%= data.site.ogImage %>">
    <meta name="theme-color" content="#0A2E73">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "EducationalOrganization",
      "name": "<%= data.site.name %>",
      "url": "<%= data.site.url %>",
      "logo": "<%= data.site.ogImage %>",
      "description": "<%= data.site.description %>",
      "sameAs": []
    }
    </script>

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        navy: {
                            50: '#f0f4fa',
                            100: '#dbe5f3',
                            200: '#bfd0ea',
                            300: '#94b2dd',
                            400: '#648ecc',
                            500: '#416db9',
                            600: '#30549b',
                            700: '#27437d',
                            800: '#233968',
                            900: '#0A2E73',
                            950: '#051b43'
                        },
                        orange: {
                            50: '#fffbeb',
                            100: '#fef3c7',
                            200: '#fde68a',
                            300: '#fcd34d',
                            400: '#fbbf24',
                            500: '#F5A623',
                            600: '#e09112',
                            700: '#b45309',
                            800: '#92400e',
                            900: '#78350f'
                        }
                    },
                    fontFamily: {
                        poppins: ['Poppins', 'sans-serif'],
                        inter: ['Inter', 'sans-serif']
                    }
                }
            }
        }
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>

    <style>
        :root {
            --text-primary: #102a43;
            --text-secondary: #334e68;
            --text-muted: #64748b;
            --surface: #ffffff;
            --surface-strong: #f8fafc;
            --border: rgba(15, 23, 42, 0.08);
            --accent: #0a2e73;
            --accent-soft: rgba(10, 46, 115, 0.12);
            --button-text: #ffffff;
        }
        body {
            font-family: 'Inter', sans-serif;
            color: var(--text-primary);
            background: #ffffff;
            overflow-x: hidden;
            font-synthesis: none;
        }
        p, li, span {
            font-family: 'Inter', sans-serif;
            color: var(--text-secondary);
        }
        button, input, textarea {
            font-family: 'Inter', sans-serif;
        }
        h1, h2, h3, h4, h5, h6 {
            font-family: 'Times New Roman', Times, serif;
            color: var(--text-primary);
            letter-spacing: -0.02em;
        }
        .primary-btn {
            background-color: #0A2E73;
            color: #ffffff;
            font-weight: 700;
            box-shadow: 0 18px 45px rgba(10, 46, 115, 0.18);
        }
        .primary-btn:hover {
            background-color: #08255a;
        }
        .primary-btn i,
        .primary-btn svg,
        .primary-btn span {
            color: #ffffff;
        }
        button[class*="bg-navy-"],
        a[class*="bg-navy-"] {
            color: #ffffff !important;
        }
        button[class*="bg-navy-"] i,
        button[class*="bg-navy-"] svg,
        button[class*="bg-navy-"] span,
        a[class*="bg-navy-"] i,
        a[class*="bg-navy-"] svg,
        a[class*="bg-navy-"] span {
            color: #ffffff !important;
        }
        .btn-text-orange {
            color: #F97316 !important;
        }
        .btn-text-white {
            color: #ffffff !important;
        }
        .page-header {
            transition: box-shadow .25s ease-out, background-color .25s ease-out, padding .25s ease-out, backdrop-filter .25s ease-out;
            background-color: rgba(255,255,255,0.98);
            will-change: transform;
        }
        .page-header .top-row,
        .page-header .nav-row {
            transition: padding .25s ease-out, border-color .25s ease-out, background-color .25s ease-out;
        }
        .page-header.condensed {
            box-shadow: 0 18px 45px rgba(15, 23, 42, 0.12);
            backdrop-filter: blur(12px);
        }
        .page-header.condensed .top-row {
            padding-top: 0.75rem;
            padding-bottom: 0.75rem;
        }
        .page-header.condensed .nav-row {
            padding-top: 0.35rem;
            padding-bottom: 0.35rem;
            border-color: rgba(148, 163, 184, 0.18);
        }
        .page-header.condensed .top-row a img {
            max-height: 52px;
        }
        .orange-glow {
            box-shadow: 0 18px 70px -44px rgba(10, 46, 115, 0.28);
        }
        .section-card {
            background: var(--surface);
            border: 1px solid var(--border);
            box-shadow: 0 16px 40px rgba(15, 23, 42, 0.06);
            backdrop-filter: blur(8px);
        }
        .hero-card {
            background: var(--surface-strong);
            border: 1px solid rgba(15, 23, 42, 0.08);
            box-shadow: 0 16px 40px rgba(15, 23, 42, 0.06);
            backdrop-filter: blur(8px);
        }
        .section-divider {
            border-color: rgba(148, 163, 184, 0.18);
        }
        .text-accent,
        .hero-highlight,
        .text-blue-600,
        .hover\:text-blue-700:hover {
            color: var(--accent) !important;
        }
        .bg-blue-600,
        .bg-blue-700 {
            background-color: var(--accent) !important;
        }
        .bg-blue-50 {
            background-color: rgba(10, 46, 115, 0.08) !important;
        }
        button[class*="bg-navy-"],
        a[class*="bg-navy-"],
        button.bg-blue-600,
        a.bg-blue-600,
        button.bg-blue-700,
        a.bg-blue-700 {
            color: #ffffff !important;
        }
        button[class*="bg-navy-"] i,
        button[class*="bg-navy-"] svg,
        button[class*="bg-navy-"] span,
        a[class*="bg-navy-"] i,
        a[class*="bg-navy-"] svg,
        a[class*="bg-navy-"] span,
        button.bg-blue-600 i,
        button.bg-blue-600 svg,
        button.bg-blue-600 span,
        a.bg-blue-600 i,
        a.bg-blue-600 svg,
        a.bg-blue-600 span,
        button.bg-blue-700 i,
        button.bg-blue-700 svg,
        button.bg-blue-700 span,
        a.bg-blue-700 i,
        a.bg-blue-700 svg,
        a.bg-blue-700 span {
            color: #ffffff !important;
        }
        .btn-secondary {
            color: #F97316 !important;
        }
        .custom-scrollbar::-webkit-scrollbar {
            height: 6px;
            width: 6px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: #eef4ff;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: var(--accent);
            border-radius: 4px;
        }
    </style>
</head>
<body class="bg-white text-slate-800 selection:bg-orange-500 selection:text-white overflow-x-hidden min-h-screen flex flex-col">

    <div class="relative z-10">
        <header class="sticky top-0 z-40 bg-slate-50 border-b border-blue-100 shadow-sm page-header">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-6 pb-5 flex flex-col md:flex-row items-center justify-between gap-5 top-row">
            <a href="#" onclick="switchTab('home')" class="flex items-center gap-4 group">
                <img src="<%= data.site.logo %>" alt="<%= data.site.name %> Logo" class="h-16 w-16 object-contain transition-transform group-hover:scale-105">
                <div>
                    <h1 class="font-extrabold text-slate-950 text-xl sm:text-2xl tracking-tight leading-tight uppercase"><%= data.site.name %></h1>
                    <p class="text-[11px] font-semibold text-indigo-600 tracking-widest uppercase mt-0.5"><%= data.site.tagline %></p>
                </div>
            </a>
            <div class="flex items-center gap-3">
                <button onclick="switchTab('partnership')" class="primary-btn hover:bg-navy-850 text-white text-xs sm:text-sm font-bold px-5 py-2.5 rounded-lg transition-all flex items-center gap-2">
                    <i data-lucide="handshake" class="w-4 h-4 text-white"></i>
                    <span>Partner Inquiry</span>
                </button>
            </div>
        </div>

        <div class="bg-white border-t border-slate-200 nav-row">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <nav class="flex items-center justify-center space-x-1 sm:space-x-2 py-2 overflow-x-auto whitespace-nowrap scrollbar-none custom-scrollbar">
                    <% data.nav.forEach(function(item) { %>
                        <button onclick="switchTab('<%= item.id %>')" id="nav-<%= item.id %>" class="px-3 sm:px-4 py-2 rounded-md text-xs sm:text-sm font-bold transition-colors text-black hover:text-black hover:bg-orange-50" style="font-family: 'Times New Roman', serif;"><%= item.label %></button>
                    <% }) %>
                </nav>
            </div>
        </div>
    </header>

    <main class="flex-grow">
        <div id="tab-content-home" class="tab-view block">
            <section class="relative pt-12 pb-20 md:py-24 bg-gradient-to-b from-slate-50 to-white overflow-hidden">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
                    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
                        <div class="lg:col-span-7 space-y-6">
                            <div class="inline-flex items-center gap-2 bg-blue-50 border border-blue-100 px-4 py-1.5 rounded-full">
                                <span class="text-xs font-bold text-navy-900 uppercase tracking-wide"><%= data.hero.tagline %></span>
                            </div>
                            <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-slate-950 leading-tight tracking-tight">
                                <%= data.hero.headline %> <br class="hidden sm:inline" />
                                <span class="text-orange-500"><%= data.hero.accentHeadline %></span>
                            </h1>
                            <p class="text-base sm:text-lg text-slate-600 leading-relaxed font-normal"><%= data.hero.paragraph %></p>

                            <div class="bg-navy-50/80 border border-navy-100 p-4 rounded-xl space-y-2">
                                <h4 class="font-bold text-navy-900 text-sm flex items-center gap-2">
                                    <i data-lucide="info" class="w-4.5 h-4.5 text-navy-900 shrink-0"></i>
                                    <span>How our Faculty operates inside your school:</span>
                                </h4>
                                <p class="text-xs text-slate-600 leading-relaxed">We do not replace your full-time school subject teachers. F2F Academy deploys specialized foundation experts specifically to teach the supplemental AEP curriculum, delivering exactly <strong>3 classes per week per section</strong>.</p>
                            </div>

                            <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4">
                                <button onclick="switchTab('partnership')" class="bg-navy-900 hover:bg-navy-850 text-white text-sm font-bold px-6 py-3.5 rounded-lg transition-all shadow-md text-center flex items-center justify-center gap-2"><span><%= data.hero.ctaPrimary %></span><i data-lucide="arrow-right" class="w-4 h-4"></i></button>
                                <button onclick="switchTab('programmes')" class="bg-white hover:bg-orange-50 border border-slate-200 text-orange-600 text-sm font-bold px-6 py-3.5 rounded-lg transition-all text-center"><%= data.hero.ctaSecondary %></button>
                            </div>
                        </div>
                        <div class="lg:col-span-5 relative">
                            <div class="hero-card rounded-3xl p-6 space-y-6">
                                <div class="flex items-center gap-3 pb-3 border-b border-slate-700/40">
                                    <img src="<%= data.site.logo %>" alt="FTF Academy Icon" class="h-10 w-10 object-contain animate-pulse">
                                    <div>
                                        <div class="text-[10px] font-extrabold text-slate-400 uppercase tracking-widest">Flagship Framework</div>
                                        <div class="text-sm font-bold text-navy-900">Academic Excellence Program</div>
                                    </div>
                                </div>
                                <% data.hero.featureCards.forEach(function(card) { %>
                                    <div class="flex gap-3">
                                        <div class="w-8 h-8 rounded-full <%= card.color %> flex items-center justify-center shrink-0"><i data-lucide="<%= card.icon %>" class="w-4.5 h-4.5"></i></div>
                                        <div><h4 class="text-xs font-bold text-navy-900 uppercase tracking-wider"><%= card.title %></h4><p class="text-xs text-slate-500 mt-0.5"><%= card.description %></p></div>
                                    </div>
                                <% }) %>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="py-16 bg-white">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                    <div class="text-center max-w-3xl mx-auto mb-12">
                        <span class="text-xs font-bold text-orange-500 uppercase tracking-widest font-mono">Academic Gap Resolution</span>
                        <h2 class="text-2xl sm:text-3xl font-extrabold text-navy-900 mt-2">Bridges to Real Problem Solving</h2>
                        <p class="text-slate-500 mt-3 text-sm sm:text-base">Relying on textbook memorization alone creates high scores but limits practical engineering and scientific application. We partner with school systems to solve this root issue.</p>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                        <% data.problems.forEach(function(problem) { %>
                            <div class="p-5 bg-slate-50 rounded-xl border border-slate-100">
                                <div class="w-10 h-10 <%= problem.badge %> rounded-lg flex items-center justify-center mb-4"><i data-lucide="<%= problem.icon %>" class="w-5.5 h-5.5"></i></div>
                                <h4 class="text-base font-bold text-navy-900 mb-2"><%= problem.title %></h4>
                                <p class="text-slate-500 text-xs leading-relaxed"><%= problem.description %></p>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </section>

            <section class="py-16 bg-slate-50 border-t border-slate-100">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
                        <div class="lg:col-span-5 space-y-4">
                            <span class="text-xs font-bold text-orange-500 uppercase tracking-widest font-mono">Our Execution Framework</span>
                            <h3 class="text-2xl sm:text-3xl font-extrabold text-navy-900">The Continuous Cycle for Excellence</h3>
                            <p class="text-slate-600 text-xs sm:text-sm leading-relaxed"><%= data.methodology.intro %></p>
                            <% data.methodology.benefits.forEach(function(benefit) { %>
                                <div class="flex items-start gap-2.5"><div class="w-5 h-5 rounded-full bg-navy-100 flex items-center justify-center shrink-0 mt-0.5 text-navy-900"><i data-lucide="check" class="w-3.5 h-3.5"></i></div><span class="text-xs text-slate-700 font-bold"><%= benefit %></span></div>
                            <% }) %>
                        </div>
                        <div class="lg:col-span-7"><div class="grid grid-cols-1 sm:grid-cols-2 gap-4"><% data.methodology.steps.forEach(function(step) { %><div class="p-4 bg-white rounded-xl border border-slate-150 space-y-1.5 shadow-sm"><div class="text-sm font-extrabold text-navy-900"><%= step.title %></div><p class="text-[11px] text-slate-500 leading-relaxed"><%= step.description %></p></div><% }) %></div></div>
                    </div>
                </div>
            </section>
        </div>

        <div id="tab-content-about" class="tab-view hidden">
            <section class="py-12 bg-slate-50">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                    <div class="mx-auto max-w-5xl rounded-[32px] bg-navy-900 px-6 py-12 text-center text-white shadow-[0_24px_80px_-32px_rgba(10,46,115,0.55)] sm:px-8">
                        <span class="text-xs font-bold text-orange-500 uppercase tracking-widest font-mono">Our Identity & Values</span>
                        <h1 class="text-2xl sm:text-4xl font-extrabold text-white">Shaping Academic Foundations</h1>
                        <p class="text-slate-300 max-w-xl mx-auto text-xs sm:text-sm">We are dedicated specialists focused on developing deep conceptual and structural clarity in core STEM disciplines inside schools.</p>
                    </div>
                </div>
            </section>
            <section class="py-12 bg-white">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="p-6 bg-slate-50 rounded-2xl border border-slate-150 space-y-3"><div class="w-10 h-10 bg-navy-50 text-navy-900 rounded-xl flex items-center justify-center"><i data-lucide="target" class="w-5.5 h-5.5"></i></div><h2 class="text-lg font-bold text-navy-900">Our Strategic Mission</h2><p class="text-slate-600 text-xs sm:text-sm leading-relaxed">To empower students and partner institutions through quality education, mentorship, and innovative learning solutions that inspire success. We resolve conceptual hurdles through structured teaching systems.</p></div>
                    <div class="p-6 bg-slate-50 rounded-2xl border border-slate-150 space-y-3"><div class="w-10 h-10 bg-orange-50 text-orange-500 rounded-xl flex items-center justify-center"><i data-lucide="eye" class="w-5.5 h-5.5"></i></div><h2 class="text-lg font-bold text-navy-900">Our Strategic Vision</h2><p class="text-slate-600 text-xs sm:text-sm leading-relaxed">To be the most trusted academic partner in shaping future-ready learners and building a better tomorrow together. We envision a system where schools deliver competitive capability under their own roof.</p></div>
                </div>
            </section>
            <section class="py-12 bg-slate-50 border-y border-slate-150">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8"><h3 class="text-xl font-extrabold text-navy-900 text-center mb-8">Our Guiding Values</h3><div class="grid grid-cols-2 md:grid-cols-5 gap-4 text-center"><% data.values.forEach(function(value) { %><div class="p-4 bg-white rounded-xl border border-slate-100 shadow-sm"><div class="font-bold text-navy-900 text-sm"><%= value %></div></div><% }) %></div></div>
            </section>
            <section class="py-16 bg-white"><div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8"><div class="text-center max-w-2xl mx-auto mb-10"><span class="text-xs font-bold text-orange-500 uppercase tracking-widest font-mono">Academic Stewardship</span><h3 class="text-2xl font-extrabold text-navy-900 mt-2">Director & Academic Leadership</h3><p class="text-slate-500 text-xs sm:text-sm">Driven by experienced curriculum architects and pedagogical administrators committed to genuine learning.</p></div><div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6"><% data.leadership.forEach(function(member) { %><div class="bg-slate-50 rounded-xl p-5 border border-slate-200/80 text-center space-y-3"><div class="w-16 h-16 bg-navy-900/10 text-navy-900 rounded-full flex items-center justify-center mx-auto"><i data-lucide="user" class="w-8 h-8"></i></div><div><h4 class="font-bold text-navy-900 text-sm sm:text-base"><%= member.name %></h4><span class="text-[10px] text-orange-500 font-bold uppercase tracking-wider block mt-0.5"><%= member.role %></span></div><p class="text-xs text-slate-500 leading-relaxed"><%= member.description %></p></div><% }) %></div></div></section>
        </div>

        <div id="tab-content-partnership" class="tab-view hidden">
            <section class="py-12 bg-slate-50">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                    <div class="mx-auto max-w-5xl rounded-[32px] bg-navy-900 px-6 py-12 text-center text-white shadow-[0_24px_80px_-32px_rgba(10,46,115,0.55)] sm:px-8">
                        <span class="text-xs font-bold text-orange-500 uppercase tracking-widest font-mono">Collaborative Institutional Growth</span>
                        <h1 class="text-2xl sm:text-4xl font-extrabold tracking-tight text-white">Your Trusted Academic Partner in Excellence</h1>
                        <p class="text-slate-300 max-w-2xl mx-auto text-xs sm:text-sm">We enrich your curriculum directly within standard timetables, boosting student outcomes through expert mentoring and targeted support.</p>
                    </div>
                </div>
            </section>
            <section class="py-16 bg-white"><div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-12 gap-12 items-start"><div class="lg:col-span-6 space-y-8"><div><h2 class="text-xl sm:text-2xl font-extrabold text-navy-900 leading-snug"><%= data.partnership.headline %></h2><p class="text-slate-500 text-sm mt-2 leading-relaxed"><%= data.partnership.description %></p></div><div class="p-5 bg-slate-50 rounded-xl border border-slate-150 space-y-4"><div class="inline-block bg-orange-500 text-white text-[10px] font-bold px-2.5 py-1 rounded"><%= data.partnership.offerLabel %></div><h3 class="text-lg font-bold text-navy-900"><%= data.partnership.offerTitle %></h3><p class="text-xs text-slate-600 leading-relaxed"><%= data.partnership.offerDescription %></p><div class="grid grid-cols-2 gap-3 text-xs pt-1"><% data.partnership.benefits.forEach(function(benefit) { %><div class="flex items-center gap-1.5 text-slate-700"><span class="w-1.5 h-1.5 rounded-full bg-navy-900"></span><span><%= benefit %></span></div><% }) %></div></div><div class="p-5 bg-navy-50/50 rounded-xl border border-navy-100 flex flex-col sm:flex-row items-center justify-between gap-4"><div class="space-y-1 text-center sm:text-left"><h4 class="font-bold text-navy-900 text-sm"><%= data.partnership.brochure.title %></h4><p class="text-xs text-slate-500"><%= data.partnership.brochure.description %></p></div><a href="<%= data.partnership.brochure.file %>" download="<%= data.partnership.brochure.file %>" class="bg-navy-900 hover:bg-navy-850 text-white font-bold text-xs px-5 py-3 rounded-lg transition-all inline-flex items-center gap-2 shrink-0"><i data-lucide="download" class="w-4 h-4"></i><span><%= data.partnership.brochure.buttonText %></span></a></div></div><div class="lg:col-span-6 bg-slate-50 p-6 sm:p-8 rounded-2xl border border-slate-150"><h3 class="text-lg font-bold text-navy-900 mb-2">School Partnership Enquiry</h3><p class="text-xs text-slate-500 mb-6">Complete the institutional pro